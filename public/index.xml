 *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

 
 :root {
 color-scheme: dark;
 --green: #00ff88;
 --green2: #00cc66;
 --green3: #004422;
 --amber: #ffcc00;
 --red: #ff3355;
 --dim: #002211;
 --bg: #050e08;
 --card: #080f0b;
 --border: #00331a;
 --glow: 0 0 8px #00ff8866, 0 0 24px #00ff8822;
 --glow-lg: 0 0 16px #00ff88aa, 0 0 48px #00ff8833;
 --scan-size: 3px;
 }

 html {
 scroll-behavior: smooth;
 background: #050e08; 
 }

 body {
 background: var(--bg);
 color: var(--green);
 font-family: 'Share Tech Mono', monospace;
 min-height: 100vh;
 overflow-x: hidden;
 position: relative;
 }

 
 body::before {
 content: '';
 position: fixed;
 inset: 0;
 background: repeating-linear-gradient(
 to bottom,
 transparent 0px,
 transparent calc(var(--scan-size) - 1px),
 rgba(0,0,0,0.18) calc(var(--scan-size) - 1px),
 rgba(0,0,0,0.18) var(--scan-size)
 );
 pointer-events: none;
 z-index: 1000;
 }

 
 body::after {
 content: '';
 position: fixed;
 inset: 0;
 background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.75) 100%);
 pointer-events: none;
 z-index: 999;
 }

 
 header {
 text-align: center;
 padding: 3rem 1rem 1.5rem;
 position: relative;
 }

 .logo {
 font-family: 'Press Start 2P', monospace;
 font-size: clamp(1.2rem, 4vw, 2.4rem);
 color: var(--green);
 text-shadow: var(--glow-lg);
 letter-spacing: 0.08em;
 animation: flicker 8s infinite;
 }

 .logo span {
 color: var(--amber);
 text-shadow: 0 0 12px #ffcc00aa, 0 0 40px #ffcc0033;
 }

 .tagline {
 font-size: 0.7rem;
 color: var(--green2);
 margin-top: 0.8rem;
 letter-spacing: 0.3em;
 text-transform: uppercase;
 opacity: 0.7;
 }

 .status-bar {
 display: flex;
 justify-content: center;
 gap: 2rem;
 margin-top: 1.4rem;
 font-size: 0.6rem;
 color: var(--green2);
 letter-spacing: 0.12em;
 }

 .status-dot {
 display: inline-block;
 width: 7px; height: 7px;
 border-radius: 50%;
 background: var(--green);
 box-shadow: var(--glow);
 margin-right: 6px;
 animation: pulse 2s infinite;
 }

 .status-dot.amber { background: var(--amber); box-shadow: 0 0 8px #ffcc0088; }
 .status-dot.red { background: var(--red); box-shadow: 0 0 8px #ff335588; }

 
 .divider {
 width: 90%;
 max-width: 1000px;
 margin: 1rem auto;
 height: 1px;
 background: linear-gradient(to right, transparent, var(--green2), transparent);
 box-shadow: 0 0 8px #00ff8844;
 }

 
 .controls {
 display: flex;
 flex-wrap: wrap;
 justify-content: center;
 gap: 0.6rem;
 padding: 0.8rem 1rem;
 max-width: 1100px;
 margin: 0 auto;
 }

 .filter-btn {
 font-family: 'Press Start 2P', monospace;
 font-size: 0.45rem;
 padding: 0.5rem 0.85rem;
 background: transparent;
 color: var(--green2);
 border: 1px solid var(--border);
 cursor: pointer;
 letter-spacing: 0.05em;
 text-transform: uppercase;
 transition: all 0.15s;
 }

 .filter-btn:hover,
 .filter-btn.active {
 background: var(--green3);
 color: var(--green);
 border-color: var(--green2);
 box-shadow: var(--glow);
 }

 .search-wrap {
