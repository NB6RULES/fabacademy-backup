    <item>
      <title>Laser Gauge Tool</title>
      <link>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge-tool/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge-tool/</guid>
      <description>&lt;h1 id=&#34;laser-gauge-tool&#34;&gt;Laser Gauge Tool&lt;a class=&#34;anchor&#34; href=&#34;#laser-gauge-tool&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;This is a parametric SVG generator for creating laser cutting test gauges. Use it to find the optimal kerf adjustment and power settings for your material.&lt;/p&gt;&#xA;&lt;style&gt;&#xD;&#xA;/* ===== Gauge Tool — Liquid Glass Theme ===== */&#xD;&#xA;.gauge-tool {&#xD;&#xA;  margin: 1.5rem 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-layout {&#xD;&#xA;  display: grid;&#xD;&#xA;  grid-template-columns: 340px 1fr;&#xD;&#xA;  grid-template-rows: 1fr auto;&#xD;&#xA;  gap: 1.25rem;&#xD;&#xA;  align-items: start;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@media (max-width: 960px) {&#xD;&#xA;  .gauge-layout {&#xD;&#xA;    grid-template-columns: 1fr;&#xD;&#xA;  }&#xD;&#xA;  .gauge-tool .preview-area { grid-column: 1; grid-row: 2; }&#xD;&#xA;  .gauge-tool .button-group { grid-column: 1; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* ---- Glass Panel (left) ---- */&#xD;&#xA;.gauge-tool .panel {&#xD;&#xA;  grid-column: 1;&#xD;&#xA;  grid-row: 1;&#xD;&#xA;  background: linear-gradient(135deg, var(--glass-bg-strong), var(--glass-bg));&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: var(--glass-radius);&#xD;&#xA;  padding: 1.25rem;&#xD;&#xA;  box-shadow: var(--shadow-elev-2);&#xD;&#xA;  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  overflow: hidden;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* ---- Section cards ---- */&#xD;&#xA;.gauge-tool .section {&#xD;&#xA;  position: relative;&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: calc(var(--glass-radius) - 0.25rem);&#xD;&#xA;  padding: 1rem 1.15rem;&#xD;&#xA;  margin-bottom: 1rem;&#xD;&#xA;  background: var(--glass-bg-soft);&#xD;&#xA;  transition: border-color 180ms ease, box-shadow 180ms ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .section:hover {&#xD;&#xA;  border-color: rgba(var(--link-rgb), 0.3);&#xD;&#xA;  box-shadow: 0 0 0 1px rgba(var(--link-rgb), 0.1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .section h3 {&#xD;&#xA;  margin: 0 0 0.5rem 0;&#xD;&#xA;  font-size: 0.9rem;&#xD;&#xA;  font-weight: 700;&#xD;&#xA;  letter-spacing: -0.01em;&#xD;&#xA;  color: var(--body-font-color);&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  gap: 0.45rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .section h3::before {&#xD;&#xA;  content: &#34;&#34;;&#xD;&#xA;  display: inline-block;&#xD;&#xA;  width: 6px;&#xD;&#xA;  height: 6px;&#xD;&#xA;  border-radius: 50%;&#xD;&#xA;  background: rgba(var(--link-rgb), 0.6);&#xD;&#xA;  flex-shrink: 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* ---- Labels &amp; Inputs ---- */&#xD;&#xA;.gauge-tool label {&#xD;&#xA;  display: block;&#xD;&#xA;  margin-top: 0.65rem;&#xD;&#xA;  font-size: 0.8rem;&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  font-weight: 500;&#xD;&#xA;  letter-spacing: 0.01em;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool input {&#xD;&#xA;  width: 100%;&#xD;&#xA;  padding: 0.55rem 0.75rem;&#xD;&#xA;  margin-top: 0.3rem;&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: 0.6rem;&#xD;&#xA;  background: var(--gray-100);&#xD;&#xA;  color: var(--body-font-color);&#xD;&#xA;  font-size: 0.9rem;&#xD;&#xA;  box-sizing: border-box;&#xD;&#xA;  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);&#xD;&#xA;  transition: border-color 180ms ease, box-shadow 180ms ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;html.dark .gauge-tool input {&#xD;&#xA;  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool input:focus {&#xD;&#xA;  outline: none;&#xD;&#xA;  border-color: rgba(var(--link-rgb), 0.6);&#xD;&#xA;  box-shadow: 0 0 0 3px rgba(var(--link-rgb), 0.15),&#xD;&#xA;              inset 0 0 0 1px rgba(var(--link-rgb), 0.1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* ---- Buttons row ---- */&#xD;&#xA;.gauge-tool .button-group {&#xD;&#xA;  grid-column: 1 / -1;&#xD;&#xA;  grid-row: 2;&#xD;&#xA;  display: grid;&#xD;&#xA;  grid-template-columns: 1fr 1fr;&#xD;&#xA;  gap: 1rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button {&#xD;&#xA;  width: 100%;&#xD;&#xA;  padding: 0.8rem 1rem;&#xD;&#xA;  border: none;&#xD;&#xA;  border-radius: 0.75rem;&#xD;&#xA;  font-size: 0.9rem;&#xD;&#xA;  font-weight: 600;&#xD;&#xA;  cursor: pointer;&#xD;&#xA;  transition: transform 150ms cubic-bezier(.4,0,.2,1),&#xD;&#xA;              box-shadow 200ms ease,&#xD;&#xA;              background 180ms ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn {&#xD;&#xA;  background: linear-gradient(135deg, rgba(var(--link-rgb), 0.9), #5856d6);&#xD;&#xA;  color: white;&#xD;&#xA;  box-shadow: 0 6px 20px rgba(var(--link-rgb), 0.3),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.2);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn:hover {&#xD;&#xA;  transform: translateY(-2px);&#xD;&#xA;  box-shadow: 0 8px 28px rgba(var(--link-rgb), 0.4),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.2);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn:active {&#xD;&#xA;  transform: translateY(0);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.download-btn {&#xD;&#xA;  background: linear-gradient(135deg, var(--glass-bg-strong), var(--glass-bg));&#xD;&#xA;  color: var(--color-link);&#xD;&#xA;  border: 1px solid var(--glass-stroke-strong);&#xD;&#xA;  box-shadow: var(--shadow-elev-2);&#xD;&#xA;  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.download-btn:hover {&#xD;&#xA;  transform: translateY(-2px);&#xD;&#xA;  border-color: rgba(var(--link-rgb), 0.4);&#xD;&#xA;  box-shadow: 0 12px 32px rgba(0,0,0,0.12);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* ---- Preview area (right) ---- */&#xD;&#xA;.gauge-tool .preview-area {&#xD;&#xA;  grid-column: 2;&#xD;&#xA;  grid-row: 1;&#xD;&#xA;  background: linear-gradient(135deg, var(--glass-bg-strong), var(--glass-bg));&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: var(--glass-radius);&#xD;&#xA;  padding: 1.25rem;&#xD;&#xA;  box-shadow: var(--shadow-elev-1);&#xD;&#xA;  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  display: flex;&#xD;&#xA;  flex-direction: column;&#xD;&#xA;  min-height: 420px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .preview-area h3 {&#xD;&#xA;  margin: 0 0 1rem 0;&#xD;&#xA;  font-size: 0.95rem;&#xD;&#xA;  font-weight: 700;&#xD;&#xA;  letter-spacing: -0.01em;&#xD;&#xA;  color: var(--body-font-color);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool #preview {&#xD;&#xA;  flex: 1;&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: calc(var(--glass-radius) - 0.25rem);&#xD;&#xA;  padding: 1.25rem;&#xD;&#xA;  background: var(--gray-100);&#xD;&#xA;  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  justify-content: center;&#xD;&#xA;  overflow: auto;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;html.dark .gauge-tool #preview {&#xD;&#xA;  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool #preview svg {&#xD;&#xA;  max-width: 100%;&#xD;&#xA;  height: auto;&#xD;&#xA;  display: block;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .preview-placeholder {&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  font-size: 0.85rem;&#xD;&#xA;  text-align: center;&#xD;&#xA;  padding: 2rem 0;&#xD;&#xA;}&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;div class=&#34;gauge-tool&#34;&gt;&#xD;&#xA;&lt;div class=&#34;gauge-layout&#34;&gt;&#xD;&#xA;&lt;!-- LEFT PANEL --&gt;&#xD;&#xA;&lt;div class=&#34;panel&#34;&gt;&#xD;&#xA;&lt;div class=&#34;section&#34;&gt;&#xD;&#xA;&lt;h3&gt;Material &amp; Kerf&lt;/h3&gt;&#xD;&#xA;&lt;p&gt;&lt;label&gt;Material thickness (mm)&lt;/label&gt;&#xA;&lt;input id=&#34;t&#34; type=&#34;number&#34; value=&#34;3&#34; step=&#34;0.01&#34;&gt;&lt;/p&gt;</description>
    </item>
