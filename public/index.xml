    <item>
      <title>Laser Gauge Tool</title>
      <link>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge-tool/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge-tool/</guid>
      <description>&lt;h1 id=&#34;laser-gauge-tool&#34;&gt;Laser Gauge Tool&lt;a class=&#34;anchor&#34; href=&#34;#laser-gauge-tool&#34;&gt;#&lt;/a&gt;&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;This is a parametric SVG generator for creating laser cutting test gauges. Use it to find the optimal kerf adjustment and power settings for your material.&lt;/p&gt;&#xA;&lt;style&gt;&#xD;&#xA;.gauge-tool {&#xD;&#xA;  font-family: system-ui, -apple-system, Segoe UI, Arial;&#xD;&#xA;  background: #f2f3f5;&#xD;&#xA;  border-radius: 12px;&#xD;&#xA;  overflow: hidden;&#xD;&#xA;  margin: 1rem 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark .gauge-tool {&#xD;&#xA;  background: #1a1a2e;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-header {&#xD;&#xA;  background: #111;&#xD;&#xA;  color: white;&#xD;&#xA;  padding: 16px 20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark .gauge-header {&#xD;&#xA;  background: #0d0d1a;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-layout {&#xD;&#xA;  display: grid;&#xD;&#xA;  grid-template-columns: 330px 1fr;&#xD;&#xA;  min-height: 500px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@media (max-width: 800px) {&#xD;&#xA;  .gauge-layout {&#xD;&#xA;    grid-template-columns: 1fr;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-panel {&#xD;&#xA;  background: white;&#xD;&#xA;  padding: 16px;&#xD;&#xA;  overflow-y: auto;&#xD;&#xA;  box-shadow: 2px 0 8px rgba(0,0,0,.08);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark .gauge-panel {&#xD;&#xA;  background: #16213e;&#xD;&#xA;  color: #e0e0e0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-section {&#xD;&#xA;  border: 1px solid #ddd;&#xD;&#xA;  border-radius: 8px;&#xD;&#xA;  padding: 12px;&#xD;&#xA;  margin-bottom: 12px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark .gauge-section {&#xD;&#xA;  border-color: #2a2a4a;&#xD;&#xA;  background: rgba(255,255,255,0.03);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-section h3 {&#xD;&#xA;  margin: 0 0 8px 0;&#xD;&#xA;  font-size: 1rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool label {&#xD;&#xA;  display: block;&#xD;&#xA;  margin-top: 8px;&#xD;&#xA;  font-size: 0.9rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool input {&#xD;&#xA;  width: 100%;&#xD;&#xA;  padding: 6px;&#xD;&#xA;  margin-top: 4px;&#xD;&#xA;  border: 1px solid #ccc;&#xD;&#xA;  border-radius: 4px;&#xD;&#xA;  box-sizing: border-box;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark .gauge-tool input {&#xD;&#xA;  background: #1a1a2e;&#xD;&#xA;  border-color: #3a3a5a;&#xD;&#xA;  color: #e0e0e0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-btn {&#xD;&#xA;  width: 100%;&#xD;&#xA;  padding: 10px;&#xD;&#xA;  margin-top: 8px;&#xD;&#xA;  border: none;&#xD;&#xA;  background: #111;&#xD;&#xA;  color: white;&#xD;&#xA;  border-radius: 6px;&#xD;&#xA;  cursor: pointer;&#xD;&#xA;  font-size: 0.95rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-btn:hover {&#xD;&#xA;  background: #333;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-btn.secondary {&#xD;&#xA;  background: #2563eb;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-btn.secondary:hover {&#xD;&#xA;  background: #1d4ed8;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-preview-area {&#xD;&#xA;  padding: 20px;&#xD;&#xA;  background: white;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark .gauge-preview-area {&#xD;&#xA;  background: #1a1a2e;&#xD;&#xA;  color: #e0e0e0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;#gauge-preview {&#xD;&#xA;  border: 1px solid #ddd;&#xD;&#xA;  padding: 10px;&#xD;&#xA;  min-height: 300px;&#xD;&#xA;  border-radius: 8px;&#xD;&#xA;  background: #fafafa;&#xD;&#xA;  overflow: auto;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark #gauge-preview {&#xD;&#xA;  border-color: #3a3a5a;&#xD;&#xA;  background: #16213e;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;#gauge-preview svg {&#xD;&#xA;  max-width: 100%;&#xD;&#xA;  height: auto;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark #gauge-preview svg text {&#xD;&#xA;  fill: #e0e0e0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;:root.dark #gauge-preview svg rect,&#xD;&#xA;:root.dark #gauge-preview svg circle {&#xD;&#xA;  stroke: #e0e0e0;&#xD;&#xA;}&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;div class=&#34;gauge-tool&#34;&gt;&#xD;&#xA;&lt;div class=&#34;gauge-header&#34;&gt;&#xD;&#xA;&lt;h2 style=&#34;margin:0;&#34;&gt;🛠️ Parametric Laser Gauge (SVG)&lt;/h2&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;gauge-layout&#34;&gt;&#xD;&#xA;&lt;div class=&#34;gauge-panel&#34;&gt;&#xD;&#xA;&lt;div class=&#34;gauge-section&#34;&gt;&#xD;&#xA;&lt;h3&gt;Material &amp; Kerf&lt;/h3&gt;&#xD;&#xA;&lt;p&gt;&lt;label&gt;Material thickness (mm)&lt;/label&gt;&#xA;&lt;input id=&#34;gauge-t&#34; type=&#34;number&#34; value=&#34;3&#34; step=&#34;0.01&#34;&gt;&lt;/p&gt;</description>
