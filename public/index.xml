&lt;style&gt;
 
:root {
 --link-rgb: 0,122,255;
 --color-link: #007aff;
 --glass-bg: rgba(255,255,255,0.55);
 --glass-bg-strong: rgba(255,255,255,0.75);
 --glass-bg-soft: rgba(255,255,255,0.35);
 --glass-stroke: rgba(0,0,0,0.08);
 --glass-stroke-strong: rgba(0,0,0,0.14);
 --glass-radius: 14px;
 --glass-blur: 18px;
 --glass-saturate: 1.6;
 --body-font-color: #1a1a1e;
 --gray-100: #f4f4f7;
 --gray-500: #7a7a8a;
 --shadow-elev-1: 0 20px 60px rgba(0,0,0,0.14), 0 4px 16px rgba(0,0,0,0.08);
 --shadow-elev-2: 0 8px 24px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.05);
}

html.dark {
 --link-rgb: 10,132,255;
 --color-link: #0a84ff;
 --glass-bg: rgba(30,30,40,0.6);
 --glass-bg-strong: rgba(40,40,55,0.75);
 --glass-bg-soft: rgba(30,30,40,0.35);
 --glass-stroke: rgba(255,255,255,0.09);
 --glass-stroke-strong: rgba(255,255,255,0.15);
 --body-font-color: #f0f0f5;
 --gray-100: #1e1e28;
 --gray-500: #888898;
 --shadow-elev-1: 0 20px 60px rgba(0,0,0,0.5), 0 4px 16px rgba(0,0,0,0.25);
 --shadow-elev-2: 0 8px 24px rgba(0,0,0,0.3), 0 2px 6px rgba(0,0,0,0.15);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
 font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
 background: var(--gray-100);
 color: var(--body-font-color);
 padding: 2rem 1.5rem;
 min-height: 100vh;
}

 
@keyframes gt-shimmer {
 0% { background-position: -200% 0; }
 100% { background-position: 200% 0; }
}
@keyframes gt-fadeUp {
 from { opacity: 0; transform: translateY(18px); }
 to { opacity: 1; transform: translateY(0); }
}
@keyframes gt-glow-pulse {
 0%, 100% { opacity: 0.5; }
 50% { opacity: 1; }
}
@keyframes gt-float {
 0%, 100% { transform: translateY(0); }
 50% { transform: translateY(-6px); }
}

 
.gt-hero {
 text-align: center;
 padding: 2.5rem 1.5rem 1.8rem;
 position: relative;
 animation: gt-fadeUp 0.6s ease both;
}
.gt-hero::before {
 content: "";
 position: absolute;
 top: -40px; left: 50%; transform: translateX(-50%);
 width: 380px; height: 380px;
 border-radius: 50%;
 background: radial-gradient(circle, rgba(var(--link-rgb), 0.18) 0%, transparent 70%);
 pointer-events: none;
 filter: blur(40px);
 animation: gt-glow-pulse 4s ease-in-out infinite;
}
.gt-badge {
 display: inline-flex;
 align-items: center;
 gap: 0.45rem;
 font-size: 0.78rem;
 font-weight: 700;
 letter-spacing: 0.06em;
 text-transform: uppercase;
 color: rgba(var(--link-rgb), 1);
 background: rgba(var(--link-rgb), 0.1);
 border: 1px solid rgba(var(--link-rgb), 0.2);
 padding: 0.4rem 1rem;
 border-radius: 999px;
 margin-bottom: 1rem;
}
.gt-badge svg { width: 14px; height: 14px; }
.gt-hero h1 {
 font-size: clamp(2rem, 4vw, 2.8rem);
 font-weight: 800;
 letter-spacing: -0.035em;
 line-height: 1.15;
 margin: 0 0 0.6rem;
 background: linear-gradient(135deg, var(--body-font-color) 40%, rgba(var(--link-rgb), 1) 100%);
 -webkit-background-clip: text;
 -webkit-text-fill-color: transparent;
 background-clip: text;
}
.gt-hero p {
 font-size: 1.05rem;
 color: var(--gray-500);
 max-width: 540px;
 margin: 0 auto;
 line-height: 1.55;
}

 
.gauge-tool {
 margin: 0.5rem 0 2rem;
 animation: gt-fadeUp 0.7s ease 0.15s both;
}
.gauge-layout {
 display: grid;
 grid-template-columns: 360px 1fr;
 grid-template-rows: 1fr auto;
 gap: 1.25rem;
 align-items: start;
}

@media (max-width: 960px) {
 .gauge-layout {
 display: flex;
 flex-direction: column;
 gap: 1.25rem;
 }
 .gauge-tool .preview-wrap { order: 2; width: 100%; }
 .gauge-tool .gt-window { width: 100%; }
 .gauge-tool .button-group { order: 3; width: 100%; }
}

 
.gt-window {
 position: relative;
 background: linear-gradient(145deg, var(--glass-bg-strong), var(--glass-bg));
 border: 1px solid var(--glass-stroke);
 border-radius: calc(var(--glass-radius) + 2px);
 box-shadow: var(--shadow-elev-2), 0 0 0 0.5px rgba(255,255,255,0.08) inset;
 -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
 backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
 overflow: hidden;
 transition: box-shadow 0.35s ease, border-color 0.35s ease;
}
.gt-window:hover {
 box-shadow: var(--shadow-elev-1), 0 0 0 0.5px rgba(255,255,255,0.12) inset;
}

.gt-titlebar {
 display: flex;
 align-items: center;
 gap: 0.5rem;
 padding: 0.75rem 1rem;
 background: linear-gradient(180deg, rgba(255,255,255,0.06), transparent);
 border-bottom: 1px solid var(--glass-stroke);
 user-select: none;
}
html.dark .gt-titlebar {
 background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent);
}

.gt-traffic { display: flex; gap: 7px; margin-right: 0.5rem; }
.gt-dot {
 width: 12px; height: 12px; border-radius: 50%;
 box-shadow: inset 0 -1px 2px rgba(0,0,0,0.15), 0 1px 2px rgba(0,0,0,0.08);
}
.gt-dot--red { background: linear-gradient(180deg, #ff6058, #e0443e); }
.gt-dot--yellow { background: linear-gradient(180deg, #ffbd2e, #dea123); }
.gt-dot--green { background: linear-gradient(180deg, #27c93f, #1aab29); }

.gt-titlebar-text {
 flex: 1;
 text-align: center;
 font-size: 0.8rem;
 font-weight: 600;
 color: var(--gray-500);
 letter-spacing: -0.005em;
}

 
.gt-body { padding: 1.25rem; }

.gauge-tool .section {
 position: relative;
 border: 1px solid var(--glass-stroke);
 border-radius: 1rem;
 padding: 1rem 1.15rem;
 margin-bottom: 1rem;
 background: var(--glass-bg-soft);
 transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
}
.gauge-tool .section:last-child { margin-bottom: 0; }
.gauge-tool .section:hover {
 border-color: rgba(var(--link-rgb), 0.35);
 box-shadow: 0 0 0 1px rgba(var(--link-rgb), 0.08), 0 8px 24px rgba(var(--link-rgb), 0.06);
 transform: translateY(-1px);
}
.gauge-tool .section h3 {
 margin: 0 0 0.35rem 0;
 font-size: 0.82rem;
 font-weight: 700;
 letter-spacing: -0.01em;
 color: var(--body-font-color);
 display: flex;
 align-items: center;
 gap: 0.5rem;
}

.gt-section-icon {
 width: 26px; height: 26px;
 border-radius: 7px;
 display: inline-flex;
 align-items: center;
 justify-content: center;
 flex-shrink: 0;
}
.gt-section-icon svg { width: 14px; height: 14px; }
.gt-section-icon--blue { background: rgba(0,122,255,0.14); color: #007aff; }
.gt-section-icon--orange { background: rgba(255,159,10,0.14); color: #ff9f0a; }
.gt-section-icon--purple { background: rgba(175,82,222,0.14); color: #af52de; }
.gt-section-icon--teal { background: rgba(48,209,88,0.14); color: #30d158; }
html.dark .gt-section-icon--blue { background: rgba(10,132,255,0.2); color: #0a84ff; }
html.dark .gt-section-icon--orange { background: rgba(255,159,10,0.2); color: #ff9f0a; }
html.dark .gt-section-icon--purple { background: rgba(191,90,242,0.2); color: #bf5af2; }
html.dark .gt-section-icon--teal { background: rgba(48,209,88,0.2); color: #30d158; }

 
.gt-row {
 display: flex;
 align-items: center;
 justify-content: space-between;
 gap: 0.75rem;
 padding: 0.55rem 0;
 border-bottom: 1px solid var(--glass-stroke);
}
.gt-row:last-child { border-bottom: none; }
.gt-row label {
 font-size: 0.82rem;
 font-weight: 500;
 color: var(--body-font-color);
 letter-spacing: -0.005em;
 white-space: nowrap;
 margin: 0;
 flex: 1;
}
.gt-row-input-group {
 display: flex;
 align-items: center;
 gap: 0.5rem;
 justify-content: flex-end;
}

.gauge-tool input[type="number"] {
 width: 90px;
 padding: 0.45rem 0.6rem;
 margin: 0;
 border: 1px solid var(--glass-stroke);
 border-radius: 0.55rem;
 background: var(--gray-100);
 color: var(--body-font-color);
 font-size: 0.85rem;
 font-weight: 500;
 text-align: right;
 box-sizing: border-box;
 box-shadow: inset 0 1px 2px rgba(0,0,0,0.04);
 transition: border-color 0.2s ease, box-shadow 0.2s ease;
 -moz-appearance: textfield;
 font-family: "SF Mono","Fira Code",ui-monospace,monospace;
}
.gauge-tool input[type="number"]::-webkit-inner-spin-button,
.gauge-tool input[type="number"]::-webkit-outer-spin-button { opacity: 0.5; }
html.dark .gauge-tool input[type="number"] { box-shadow: inset 0 1px 2px rgba(0,0,0,0.2); }
.gauge-tool input[type="number"]:focus {
 outline: none;
 border-color: rgba(var(--link-rgb), 0.6);
 box-shadow: 0 0 0 3.5px rgba(var(--link-rgb), 0.12), inset 0 1px 2px rgba(0,0,0,0.04);
}

.gt-unit {
 font-size: 0.72rem;
 font-weight: 600;
 color: var(--gray-500);
 min-width: 28px;
}

 
.gauge-tool .preview-wrap {
 grid-column: 2;
 grid-row: 1;
}
.gauge-tool #preview {
 flex: 1;
 border: 1px solid var(--glass-stroke);
 border-radius: 0.85rem;
 padding: 1.25rem;
 background: var(--gray-100);
 box-shadow: inset 0 1px 3px rgba(0,0,0,0.04);
 display: flex;
 align-items: center;
 justify-content: center;
 overflow: auto;
 min-height: 380px;
 position: relative;
}
html.dark .gauge-tool #preview {
 background: #fff;
 box-shadow: inset 0 1px 3px rgba(0,0,0,0.06);
}
.gauge-tool #preview svg { max-width: 100%; height: auto; display: block; }

.gt-placeholder {
 display: flex;
 flex-direction: column;
 align-items: center;
 gap: 0.75rem;
 color: var(--gray-500);
 text-align: center;
 padding: 2rem 1rem;
 word-break: break-word;
}
.gt-placeholder svg {
 width: 48px; height: 48px;
 opacity: 0.35;
 animation: gt-float 3s ease-in-out infinite;
}
.gt-placeholder span { font-size: 0.85rem; font-weight: 500; }

 
.gauge-tool .button-group {
 grid-column: 1 / -1;
 grid-row: 2;
 display: grid;
 grid-template-columns: 1fr 1fr 1fr;
 gap: 1rem;
}
.gauge-tool button {
 display: inline-flex;
 align-items: center;
 justify-content: center;
 gap: 0.5rem;
 width: 100%;
 padding: 0.85rem 1.2rem;
 border: none;
 border-radius: 0.85rem;
 font-size: 0.9rem;
 font-weight: 650;
 cursor: pointer;
 letter-spacing: -0.01em;
 transition: transform 0.2s cubic-bezier(.4,0,.2,1), box-shadow 0.25s ease, background 0.2s ease, filter 0.2s ease;
}
.gauge-tool button svg { width: 18px; height: 18px; }
.gauge-tool button.generate-btn {
 background: linear-gradient(135deg, rgba(var(--link-rgb), 0.92), #5856d6);
 color: white;
 box-shadow: 0 6px 22px rgba(var(--link-rgb), 0.32), inset 0 1px 0 rgba(255,255,255,0.22);
 position: relative;
 overflow: hidden;
}
.gauge-tool button.generate-btn::after {
 content: "";
 position: absolute;
 inset: 0;
 background: linear-gradient(105deg,transparent 40%,rgba(255,255,255,0.12) 45%,rgba(255,255,255,0.18) 50%,rgba(255,255,255,0.12) 55%,transparent 60%);
 background-size: 200% 100%;
 animation: gt-shimmer 3s ease-in-out infinite;
 pointer-events: none;
}
.gauge-tool button.generate-btn:hover {
 transform: translateY(-2px) scale(1.01);
 box-shadow: 0 10px 32px rgba(var(--link-rgb), 0.42), inset 0 1px 0 rgba(255,255,255,0.22);
 filter: brightness(1.08);
}
.gauge-tool button.generate-btn:active {
 transform: translateY(0) scale(0.98);
 box-shadow: 0 4px 14px rgba(var(--link-rgb), 0.25), inset 0 1px 0 rgba(255,255,255,0.22);
}
.gauge-tool button.download-btn {
 background: linear-gradient(145deg, var(--glass-bg-strong), var(--glass-bg));
 color: var(--color-link);
 border: 1px solid var(--glass-stroke-strong);
 box-shadow: var(--shadow-elev-2), inset 0 1px 0 rgba(255,255,255,0.1);
 -webkit-backdrop-filter: blur(var(--glass-blur));
 backdrop-filter: blur(var(--glass-blur));
}
.gauge-tool button.download-btn:hover {
 transform: translateY(-2px) scale(1.01);
 border-color: rgba(var(--link-rgb), 0.45);
 box-shadow: 0 14px 36px rgba(0,0,0,0.14), inset 0 1px 0 rgba(255,255,255,0.1);
}
.gauge-tool button.download-btn:active { transform: translateY(0) scale(0.98); }

 
.gt-toast {
 position: fixed;
 bottom: 2rem;
 left: 50%;
 transform: translateX(-50%) translateY(20px);
 padding: 0.65rem 1.2rem;
 border-radius: 999px;
 font-size: 0.82rem;
 font-weight: 600;
 color: #fff;
 background: rgba(40,40,40,0.88);
 border: 1px solid rgba(255,255,255,0.12);
 box-shadow: 0 12px 40px rgba(0,0,0,0.3);
 -webkit-backdrop-filter: blur(20px) saturate(1.8);
 backdrop-filter: blur(20px) saturate(1.8);
 opacity: 0;
 pointer-events: none;
 z-index: 9999;
 transition: all 0.4s cubic-bezier(.4,0,.2,1);
 display: flex;
 align-items: center;
 gap: 0.4rem;
}
html.dark .gt-toast { background: rgba(60,60,60,0.9); }
.gt-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

 
.gt-footer {
 text-align: center;
 margin-top: 1.5rem;
 padding: 1.2rem;
 border-radius: var(--glass-radius);
 background: linear-gradient(135deg, rgba(var(--link-rgb), 0.04), rgba(var(--link-rgb), 0.01));
 border: 1px solid rgba(var(--link-rgb), 0.12);
 animation: gt-fadeUp 0.8s ease 0.3s both;
}
.gt-footer p {
 font-size: 0.82rem;
 color: var(--gray-500);
 margin: 0;
 line-height: 1.5;
}
.gt-footer strong { color: var(--color-link); }

@media (max-width: 960px) {
 .gt-hero { padding: 1.5rem 1rem 1.2rem; }
 .gt-hero h1 { font-size: 1.8rem; }
 .gauge-layout { gap: 1rem; }
 .gauge-tool .button-group { grid-template-columns: 1fr; } .gauge-tool #preview { min-height: 220px; padding: 1rem; }
 .gauge-tool .gt-body { padding: 1rem; }
 .gt-placeholder span { font-size: 0.78rem; }
}
