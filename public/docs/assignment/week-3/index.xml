    <item>
      <title>Laser Gauge Tool</title>
      <link>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge-tool/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge-tool/</guid>
      <description>&lt;style&gt;&#xD;&#xA;/* ===== Gauge Tool — Apple Liquid Glass 2.0 ===== */&#xD;&#xA;&#xD;&#xA;/* --- Keyframes --- */&#xD;&#xA;@keyframes gt-shimmer {&#xD;&#xA;  0%   { background-position: -200% 0; }&#xD;&#xA;  100% { background-position: 200% 0; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@keyframes gt-fadeUp {&#xD;&#xA;  from { opacity: 0; transform: translateY(18px); }&#xD;&#xA;  to   { opacity: 1; transform: translateY(0); }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@keyframes gt-glow-pulse {&#xD;&#xA;  0%, 100% { opacity: 0.5; }&#xD;&#xA;  50%      { opacity: 1; }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@keyframes gt-float {&#xD;&#xA;  0%, 100% { transform: translateY(0); }&#xD;&#xA;  50%      { transform: translateY(-6px); }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Hero --- */&#xD;&#xA;.gt-hero {&#xD;&#xA;  text-align: center;&#xD;&#xA;  padding: 2.5rem 1.5rem 1.8rem;&#xD;&#xA;  position: relative;&#xD;&#xA;  animation: gt-fadeUp 0.6s ease both;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-hero::before {&#xD;&#xA;  content: &#34;&#34;;&#xD;&#xA;  position: absolute;&#xD;&#xA;  top: -40px; left: 50%; transform: translateX(-50%);&#xD;&#xA;  width: 380px; height: 380px;&#xD;&#xA;  border-radius: 50%;&#xD;&#xA;  background: radial-gradient(circle, rgba(var(--link-rgb), 0.18) 0%, transparent 70%);&#xD;&#xA;  pointer-events: none;&#xD;&#xA;  filter: blur(40px);&#xD;&#xA;  animation: gt-glow-pulse 4s ease-in-out infinite;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-badge {&#xD;&#xA;  display: inline-flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  gap: 0.45rem;&#xD;&#xA;  font-size: 0.78rem;&#xD;&#xA;  font-weight: 700;&#xD;&#xA;  letter-spacing: 0.06em;&#xD;&#xA;  text-transform: uppercase;&#xD;&#xA;  color: rgba(var(--link-rgb), 1);&#xD;&#xA;  background: rgba(var(--link-rgb), 0.1);&#xD;&#xA;  border: 1px solid rgba(var(--link-rgb), 0.2);&#xD;&#xA;  padding: 0.4rem 1rem;&#xD;&#xA;  border-radius: 999px;&#xD;&#xA;  margin-bottom: 1rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-badge svg { width: 14px; height: 14px; }&#xD;&#xA;&#xD;&#xA;.gt-hero h1 {&#xD;&#xA;  font-size: clamp(2rem, 4vw, 2.8rem);&#xD;&#xA;  font-weight: 800;&#xD;&#xA;  letter-spacing: -0.035em;&#xD;&#xA;  line-height: 1.15;&#xD;&#xA;  margin: 0 0 0.6rem;&#xD;&#xA;  background: linear-gradient(135deg, var(--body-font-color) 40%, rgba(var(--link-rgb), 1) 100%);&#xD;&#xA;  -webkit-background-clip: text;&#xD;&#xA;  -webkit-text-fill-color: transparent;&#xD;&#xA;  background-clip: text;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-hero p {&#xD;&#xA;  font-size: 1.05rem;&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  max-width: 540px;&#xD;&#xA;  margin: 0 auto;&#xD;&#xA;  line-height: 1.55;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Main Layout --- */&#xD;&#xA;.gauge-tool {&#xD;&#xA;  margin: 0.5rem 0 2rem;&#xD;&#xA;  animation: gt-fadeUp 0.7s ease 0.15s both;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-layout {&#xD;&#xA;  display: grid;&#xD;&#xA;  grid-template-columns: 360px 1fr;&#xD;&#xA;  grid-template-rows: 1fr auto;&#xD;&#xA;  gap: 1.25rem;&#xD;&#xA;  align-items: start;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;@media (max-width: 960px) {&#xD;&#xA;  .gauge-layout {&#xD;&#xA;    display: flex;&#xD;&#xA;    flex-direction: column;&#xD;&#xA;    gap: 1.25rem;&#xD;&#xA;  }&#xD;&#xA;  .gauge-tool .preview-wrap {&#xD;&#xA;    grid-column: unset;&#xD;&#xA;    grid-row: unset;&#xD;&#xA;    order: 2;&#xD;&#xA;    width: 100%;&#xD;&#xA;  }&#xD;&#xA;  .gauge-tool .gt-window {&#xD;&#xA;    width: 100%;&#xD;&#xA;  }&#xD;&#xA;  .gauge-tool .button-group {&#xD;&#xA;    grid-column: unset;&#xD;&#xA;    grid-row: unset;&#xD;&#xA;    order: 3;&#xD;&#xA;    width: 100%;&#xD;&#xA;  }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- macOS Window Chrome --- */&#xD;&#xA;.gt-window {&#xD;&#xA;  position: relative;&#xD;&#xA;  background: linear-gradient(145deg, var(--glass-bg-strong), var(--glass-bg));&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: calc(var(--glass-radius) + 2px);&#xD;&#xA;  box-shadow: var(--shadow-elev-2),&#xD;&#xA;              0 0 0 0.5px rgba(255,255,255,0.08) inset;&#xD;&#xA;  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));&#xD;&#xA;  overflow: hidden;&#xD;&#xA;  transition: box-shadow 0.35s ease, border-color 0.35s ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-window:hover {&#xD;&#xA;  box-shadow: var(--shadow-elev-1),&#xD;&#xA;              0 0 0 0.5px rgba(255,255,255,0.12) inset;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* Titlebar with traffic lights */&#xD;&#xA;.gt-titlebar {&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  gap: 0.5rem;&#xD;&#xA;  padding: 0.75rem 1rem;&#xD;&#xA;  background: linear-gradient(180deg, rgba(255,255,255,0.06), transparent);&#xD;&#xA;  border-bottom: 1px solid var(--glass-stroke);&#xD;&#xA;  user-select: none;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;html.dark .gt-titlebar {&#xD;&#xA;  background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-traffic {&#xD;&#xA;  display: flex;&#xD;&#xA;  gap: 7px;&#xD;&#xA;  margin-right: 0.5rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-dot {&#xD;&#xA;  width: 12px;&#xD;&#xA;  height: 12px;&#xD;&#xA;  border-radius: 50%;&#xD;&#xA;  box-shadow: inset 0 -1px 2px rgba(0,0,0,0.15),&#xD;&#xA;              0 1px 2px rgba(0,0,0,0.08);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-dot--red    { background: linear-gradient(180deg, #ff6058, #e0443e); }&#xD;&#xA;.gt-dot--yellow { background: linear-gradient(180deg, #ffbd2e, #dea123); }&#xD;&#xA;.gt-dot--green  { background: linear-gradient(180deg, #27c93f, #1aab29); }&#xD;&#xA;&#xD;&#xA;.gt-titlebar-text {&#xD;&#xA;  flex: 1;&#xD;&#xA;  text-align: center;&#xD;&#xA;  font-size: 0.8rem;&#xD;&#xA;  font-weight: 600;&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  letter-spacing: -0.005em;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Panel Body --- */&#xD;&#xA;.gt-body {&#xD;&#xA;  padding: 1.25rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Section cards inside panel --- */&#xD;&#xA;.gauge-tool .section {&#xD;&#xA;  position: relative;&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: 1rem;&#xD;&#xA;  padding: 1rem 1.15rem;&#xD;&#xA;  margin-bottom: 1rem;&#xD;&#xA;  background: var(--glass-bg-soft);&#xD;&#xA;  transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .section:last-child { margin-bottom: 0; }&#xD;&#xA;&#xD;&#xA;.gauge-tool .section:hover {&#xD;&#xA;  border-color: rgba(var(--link-rgb), 0.35);&#xD;&#xA;  box-shadow: 0 0 0 1px rgba(var(--link-rgb), 0.08),&#xD;&#xA;              0 8px 24px rgba(var(--link-rgb), 0.06);&#xD;&#xA;  transform: translateY(-1px);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool .section h3 {&#xD;&#xA;  margin: 0 0 0.35rem 0;&#xD;&#xA;  font-size: 0.82rem;&#xD;&#xA;  font-weight: 700;&#xD;&#xA;  letter-spacing: -0.01em;&#xD;&#xA;  color: var(--body-font-color);&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  gap: 0.5rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-section-icon {&#xD;&#xA;  width: 26px; height: 26px;&#xD;&#xA;  border-radius: 7px;&#xD;&#xA;  display: inline-flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  justify-content: center;&#xD;&#xA;  flex-shrink: 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-section-icon svg { width: 14px; height: 14px; }&#xD;&#xA;&#xD;&#xA;.gt-section-icon--blue   { background: rgba(0,122,255,0.14); color: #007aff; }&#xD;&#xA;.gt-section-icon--orange { background: rgba(255,159,10,0.14); color: #ff9f0a; }&#xD;&#xA;.gt-section-icon--purple { background: rgba(175,82,222,0.14); color: #af52de; }&#xD;&#xA;&#xD;&#xA;html.dark .gt-section-icon--blue   { background: rgba(10,132,255,0.2); color: #0a84ff; }&#xD;&#xA;html.dark .gt-section-icon--orange { background: rgba(255,159,10,0.2); color: #ff9f0a; }&#xD;&#xA;html.dark .gt-section-icon--purple { background: rgba(191,90,242,0.2); color: #bf5af2; }&#xD;&#xA;&#xD;&#xA;/* --- iOS-style form rows --- */&#xD;&#xA;.gt-row {&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  justify-content: space-between;&#xD;&#xA;  gap: 0.75rem;&#xD;&#xA;  padding: 0.55rem 0;&#xD;&#xA;  border-bottom: 1px solid var(--glass-stroke);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-row:last-child { border-bottom: none; }&#xD;&#xA;&#xD;&#xA;.gt-row label {&#xD;&#xA;  font-size: 0.82rem;&#xD;&#xA;  font-weight: 500;&#xD;&#xA;  color: var(--body-font-color);&#xD;&#xA;  letter-spacing: -0.005em;&#xD;&#xA;  white-space: nowrap;&#xD;&#xA;  margin: 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool input[type=&#34;number&#34;] {&#xD;&#xA;  width: 90px;&#xD;&#xA;  padding: 0.45rem 0.6rem;&#xD;&#xA;  margin: 0;&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: 0.55rem;&#xD;&#xA;  background: var(--gray-100);&#xD;&#xA;  color: var(--body-font-color);&#xD;&#xA;  font-size: 0.85rem;&#xD;&#xA;  font-weight: 500;&#xD;&#xA;  text-align: right;&#xD;&#xA;  box-sizing: border-box;&#xD;&#xA;  box-shadow: inset 0 1px 2px rgba(0,0,0,0.04);&#xD;&#xA;  transition: border-color 0.2s ease, box-shadow 0.2s ease;&#xD;&#xA;  -moz-appearance: textfield;&#xD;&#xA;  font-family: &#34;SF Mono&#34;, &#34;Fira Code&#34;, ui-monospace, monospace;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool input[type=&#34;number&#34;]::-webkit-inner-spin-button,&#xD;&#xA;.gauge-tool input[type=&#34;number&#34;]::-webkit-outer-spin-button {&#xD;&#xA;  opacity: 0.5;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;html.dark .gauge-tool input[type=&#34;number&#34;] {&#xD;&#xA;  box-shadow: inset 0 1px 2px rgba(0,0,0,0.2);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool input[type=&#34;number&#34;]:focus {&#xD;&#xA;  outline: none;&#xD;&#xA;  border-color: rgba(var(--link-rgb), 0.6);&#xD;&#xA;  box-shadow: 0 0 0 3.5px rgba(var(--link-rgb), 0.12),&#xD;&#xA;              inset 0 1px 2px rgba(0,0,0,0.04);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-unit {&#xD;&#xA;  font-size: 0.72rem;&#xD;&#xA;  font-weight: 600;&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  min-width: 28px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Preview Window --- */&#xD;&#xA;.gauge-tool .preview-wrap {&#xD;&#xA;  grid-column: 2;&#xD;&#xA;  grid-row: 1;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool #preview {&#xD;&#xA;  flex: 1;&#xD;&#xA;  border: 1px solid var(--glass-stroke);&#xD;&#xA;  border-radius: 0.85rem;&#xD;&#xA;  padding: 1.25rem;&#xD;&#xA;  background: var(--gray-100);&#xD;&#xA;  box-shadow: inset 0 1px 3px rgba(0,0,0,0.04);&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  justify-content: center;&#xD;&#xA;  overflow: auto;&#xD;&#xA;  min-height: 380px;&#xD;&#xA;  position: relative;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;html.dark .gauge-tool #preview {&#xD;&#xA;  background: #fff;&#xD;&#xA;  box-shadow: inset 0 1px 3px rgba(0,0,0,0.06);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool #preview svg {&#xD;&#xA;  max-width: 100%;&#xD;&#xA;  height: auto;&#xD;&#xA;  display: block;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* Placeholder with animated icon */&#xD;&#xA;.gt-placeholder {&#xD;&#xA;  display: flex;&#xD;&#xA;  flex-direction: column;&#xD;&#xA;  align-items: center;&#xD;&#xA;  gap: 0.75rem;&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  text-align: center;&#xD;&#xA;  padding: 2rem 1rem;&#xD;&#xA;  word-break: break-word;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-placeholder svg {&#xD;&#xA;  width: 48px; height: 48px;&#xD;&#xA;  opacity: 0.35;&#xD;&#xA;  animation: gt-float 3s ease-in-out infinite;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-placeholder span {&#xD;&#xA;  font-size: 0.85rem;&#xD;&#xA;  font-weight: 500;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Buttons --- */&#xD;&#xA;.gauge-tool .button-group {&#xD;&#xA;  grid-column: 1 / -1;&#xD;&#xA;  grid-row: 2;&#xD;&#xA;  display: grid;&#xD;&#xA;  grid-template-columns: 1fr 1fr;&#xD;&#xA;  gap: 1rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button {&#xD;&#xA;  display: inline-flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  justify-content: center;&#xD;&#xA;  gap: 0.5rem;&#xD;&#xA;  width: 100%;&#xD;&#xA;  padding: 0.85rem 1.2rem;&#xD;&#xA;  border: none;&#xD;&#xA;  border-radius: 0.85rem;&#xD;&#xA;  font-size: 0.9rem;&#xD;&#xA;  font-weight: 650;&#xD;&#xA;  cursor: pointer;&#xD;&#xA;  letter-spacing: -0.01em;&#xD;&#xA;  transition: transform 0.2s cubic-bezier(.4,0,.2,1),&#xD;&#xA;              box-shadow 0.25s ease,&#xD;&#xA;              background 0.2s ease,&#xD;&#xA;              filter 0.2s ease;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button svg { width: 18px; height: 18px; }&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn {&#xD;&#xA;  background: linear-gradient(135deg, rgba(var(--link-rgb), 0.92), #5856d6);&#xD;&#xA;  color: white;&#xD;&#xA;  box-shadow: 0 6px 22px rgba(var(--link-rgb), 0.32),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.22);&#xD;&#xA;  position: relative;&#xD;&#xA;  overflow: hidden;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn::after {&#xD;&#xA;  content: &#34;&#34;;&#xD;&#xA;  position: absolute;&#xD;&#xA;  inset: 0;&#xD;&#xA;  background: linear-gradient(&#xD;&#xA;    105deg,&#xD;&#xA;    transparent 40%,&#xD;&#xA;    rgba(255,255,255,0.12) 45%,&#xD;&#xA;    rgba(255,255,255,0.18) 50%,&#xD;&#xA;    rgba(255,255,255,0.12) 55%,&#xD;&#xA;    transparent 60%&#xD;&#xA;  );&#xD;&#xA;  background-size: 200% 100%;&#xD;&#xA;  animation: gt-shimmer 3s ease-in-out infinite;&#xD;&#xA;  pointer-events: none;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn:hover {&#xD;&#xA;  transform: translateY(-2px) scale(1.01);&#xD;&#xA;  box-shadow: 0 10px 32px rgba(var(--link-rgb), 0.42),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.22);&#xD;&#xA;  filter: brightness(1.08);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.generate-btn:active {&#xD;&#xA;  transform: translateY(0) scale(0.98);&#xD;&#xA;  box-shadow: 0 4px 14px rgba(var(--link-rgb), 0.25),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.22);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.download-btn {&#xD;&#xA;  background: linear-gradient(145deg, var(--glass-bg-strong), var(--glass-bg));&#xD;&#xA;  color: var(--color-link);&#xD;&#xA;  border: 1px solid var(--glass-stroke-strong);&#xD;&#xA;  box-shadow: var(--shadow-elev-2),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.1);&#xD;&#xA;  -webkit-backdrop-filter: blur(var(--glass-blur));&#xD;&#xA;  backdrop-filter: blur(var(--glass-blur));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.download-btn:hover {&#xD;&#xA;  transform: translateY(-2px) scale(1.01);&#xD;&#xA;  border-color: rgba(var(--link-rgb), 0.45);&#xD;&#xA;  box-shadow: 0 14px 36px rgba(0,0,0,0.14),&#xD;&#xA;              inset 0 1px 0 rgba(255,255,255,0.1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gauge-tool button.download-btn:active {&#xD;&#xA;  transform: translateY(0) scale(0.98);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Status Toast --- */&#xD;&#xA;.gt-toast {&#xD;&#xA;  position: fixed;&#xD;&#xA;  bottom: 2rem;&#xD;&#xA;  left: 50%;&#xD;&#xA;  transform: translateX(-50%) translateY(20px);&#xD;&#xA;  padding: 0.65rem 1.2rem;&#xD;&#xA;  border-radius: 999px;&#xD;&#xA;  font-size: 0.82rem;&#xD;&#xA;  font-weight: 600;&#xD;&#xA;  color: #fff;&#xD;&#xA;  background: rgba(40,40,40,0.88);&#xD;&#xA;  border: 1px solid rgba(255,255,255,0.12);&#xD;&#xA;  box-shadow: 0 12px 40px rgba(0,0,0,0.3);&#xD;&#xA;  -webkit-backdrop-filter: blur(20px) saturate(1.8);&#xD;&#xA;  backdrop-filter: blur(20px) saturate(1.8);&#xD;&#xA;  opacity: 0;&#xD;&#xA;  pointer-events: none;&#xD;&#xA;  z-index: 9999;&#xD;&#xA;  transition: all 0.4s cubic-bezier(.4,0,.2,1);&#xD;&#xA;  display: flex;&#xD;&#xA;  align-items: center;&#xD;&#xA;  gap: 0.4rem;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;html.dark .gt-toast {&#xD;&#xA;  background: rgba(60,60,60,0.9);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-toast.show {&#xD;&#xA;  opacity: 1;&#xD;&#xA;  transform: translateX(-50%) translateY(0);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;/* --- Footer Tip --- */&#xD;&#xA;.gt-footer {&#xD;&#xA;  text-align: center;&#xD;&#xA;  margin-top: 1.5rem;&#xD;&#xA;  padding: 1.2rem;&#xD;&#xA;  border-radius: var(--glass-radius);&#xD;&#xA;  background: linear-gradient(135deg, rgba(var(--link-rgb), 0.04), rgba(var(--link-rgb), 0.01));&#xD;&#xA;  border: 1px solid rgba(var(--link-rgb), 0.12);&#xD;&#xA;  animation: gt-fadeUp 0.8s ease 0.3s both;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-footer p {&#xD;&#xA;  font-size: 0.82rem;&#xD;&#xA;  color: var(--gray-500);&#xD;&#xA;  margin: 0;&#xD;&#xA;  line-height: 1.5;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.gt-footer strong { color: var(--color-link); }&#xD;&#xA;&#xD;&#xA;/* --- Responsive tweaks --- */&#xD;&#xA;@media (max-width: 960px) {&#xD;&#xA;  .gt-hero { padding: 1.5rem 1rem 1.2rem; }&#xD;&#xA;  .gt-hero h1 { font-size: 1.8rem; }&#xD;&#xA;  .gauge-layout { gap: 1rem; }&#xD;&#xA;  .gauge-tool .button-group { grid-template-columns: 1fr; }&#xD;&#xA;  .gauge-tool #preview { min-height: 220px; padding: 1rem; }&#xD;&#xA;  .gauge-tool .gt-body { padding: 1rem; }&#xD;&#xA;  .gt-placeholder span { font-size: 0.78rem; }&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;div class=&#34;gt-hero&#34;&gt;&#xD;&#xA;&lt;div class=&#34;gt-badge&#34;&gt;&#xD;&#xA;&lt;svg xmlns=&#34;http://www.w3.org/2000/svg&#34; viewBox=&#34;0 0 24 24&#34; fill=&#34;none&#34; stroke=&#34;currentColor&#34; stroke-width=&#34;2.5&#34; stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34;&gt;&lt;path d=&#34;M12 2L2 7l10 5 10-5-10-5z&#34;/&gt;&lt;path d=&#34;M2 17l10 5 10-5&#34;/&gt;&lt;path d=&#34;M2 12l10 5 10-5&#34;/&gt;&lt;/svg&gt;&#xD;&#xA;Parametric Generator&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;h1&gt;Laser Gauge Tool&lt;/h1&gt;&#xD;&#xA;&lt;p&gt;Generate precision laser-cut test gauges to dial in kerf and power settings for any material.&lt;/p&gt;</description>
