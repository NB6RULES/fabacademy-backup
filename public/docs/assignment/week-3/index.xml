    <item>
      <title>Laser Gauge Tool</title>
      <link>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://fabacademy.org/2026/labs/kochi/students/nadec-biju/docs/assignment/week-3/laser-gauge/</guid>
      <description>&lt;link rel=&#34;preconnect&#34; href=&#34;https://fonts.googleapis.com&#34;&gt;&#xA;&lt;link href=&#34;https://fonts.googleapis.com/css2?family=Share+Tech+Mono&amp;family=Barlow+Condensed:wght@400;600;700;900&amp;family=IBM+Plex+Mono:wght@400;500&amp;display=swap&#34; rel=&#34;stylesheet&#34;&gt;&#xA;&#xA;&lt;style&gt;&#xA; &#xA;.lg-wrap {&#xA;  --bg:          #0d0d0d;&#xA;  --surface:     #141414;&#xA;  --panel:       #1a1a1a;&#xA;  --border:      #2e2e2e;&#xA;  --border-hi:   #444;&#xA;  --orange:      #ff6a00;&#xA;  --orange-dim:  #7a3200;&#xA;  --orange-glow: rgba(255,106,0,0.18);&#xA;  --green:       #00ff88;&#xA;  --text:        #e8e8e8;&#xA;  --muted:       #666;&#xA;  --mono:        &#34;IBM Plex Mono&#34;, &#34;Share Tech Mono&#34;, monospace;&#xA;  --head:        &#34;Barlow Condensed&#34;, sans-serif;&#xA;  --scan-line:   rgba(255,255,255,0.018);&#xA;&#xA;  font-family: var(--mono);&#xA;  color: var(--text);&#xA;  background-color: var(--bg);&#xA;  background-image: radial-gradient(circle, #2a2a2a 1px, transparent 1px);&#xA;  background-size: 28px 28px;&#xA;  position: relative;&#xA;  overflow: hidden;&#xA;  border-radius: 8px;&#xA;  border: 1px solid var(--border);&#xA;  margin: 2rem 0;&#xA;}&#xA;&#xA;.lg-wrap *, .lg-wrap *::before, .lg-wrap *::after {&#xA;  box-sizing: border-box;&#xA;}&#xA;&#xA; &#xA;.lg-wrap::before {&#xA;  content: &#34;&#34;;&#xA;  position: absolute; inset: 0;&#xA;  background: repeating-linear-gradient(&#xA;    0deg, transparent, transparent 3px,&#xA;    var(--scan-line) 3px, var(--scan-line) 4px&#xA;  );&#xA;  pointer-events: none;&#xA;  z-index: 100;&#xA;}&#xA;&#xA; &#xA;.lg-header {&#xA;  display: flex;&#xA;  align-items: center;&#xA;  justify-content: space-between;&#xA;  padding: 1.2rem 2rem;&#xA;  border-bottom: 1px solid var(--border);&#xA;  background: linear-gradient(180deg, rgba(255,106,0,0.04), transparent);&#xA;  position: relative;&#xA;}&#xA;.lg-header::after {&#xA;  content: &#34;&#34;;&#xA;  position: absolute;&#xA;  bottom: 0; left: 0; right: 0; height: 1px;&#xA;  background: linear-gradient(90deg, transparent, var(--orange), transparent);&#xA;  opacity: 0.5;&#xA;}&#xA;.lg-logo { display: flex; align-items: center; gap: 0.9rem; }&#xA;.lg-logo-icon {&#xA;  width: 34px; height: 34px;&#xA;  border: 1.5px solid var(--orange);&#xA;  border-radius: 4px;&#xA;  display: flex; align-items: center; justify-content: center;&#xA;  position: relative; overflow: hidden; flex-shrink: 0;&#xA;}&#xA;.lg-logo-icon::before {&#xA;  content: &#34;&#34;;&#xA;  position: absolute;&#xA;  width: 100%; height: 2px;&#xA;  background: var(--orange);&#xA;  top: 50%; left: -100%;&#xA;  animation: lg-laser 2.5s ease-in-out infinite;&#xA;  box-shadow: 0 0 8px var(--orange);&#xA;}&#xA;@keyframes lg-laser {&#xA;  0%   { left: -100%; opacity: 0; }&#xA;  10%  { opacity: 1; }&#xA;  90%  { opacity: 1; }&#xA;  100% { left: 100%; opacity: 0; }&#xA;}&#xA;.lg-logo-icon svg { width: 16px; height: 16px; color: var(--orange); }&#xA;.lg-logo-text {&#xA;  font-family: var(--head);&#xA;  font-weight: 900; font-size: 1.4rem;&#xA;  letter-spacing: 0.12em; text-transform: uppercase;&#xA;  color: var(--text); margin: 0;&#xA;}&#xA;.lg-logo-text span { color: var(--orange); }&#xA;.lg-header-meta {&#xA;  font-family: var(--mono); font-size: 0.66rem;&#xA;  color: var(--muted); text-align: right;&#xA;  letter-spacing: 0.04em; line-height: 1.7;&#xA;}&#xA;.lg-status-dot {&#xA;  display: inline-block; width: 6px; height: 6px;&#xA;  border-radius: 50%; background: var(--green);&#xA;  margin-right: 5px; box-shadow: 0 0 6px var(--green);&#xA;  animation: lg-blink 2s ease-in-out infinite;&#xA;}&#xA;@keyframes lg-blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }&#xA;&#xA; &#xA;.lg-main {&#xA;  display: grid;&#xA;  grid-template-columns: 320px 1fr;&#xA;}&#xA;&#xA; &#xA;.lg-params {&#xA;  border-right: 1px solid var(--border);&#xA;  padding: 1.25rem;&#xA;  background: var(--surface);&#xA;  display: flex; flex-direction: column; gap: 0.9rem;&#xA;}&#xA;.lg-section-title {&#xA;  font-family: var(--head); font-size: 0.68rem; font-weight: 700;&#xA;  letter-spacing: 0.16em; text-transform: uppercase;&#xA;  color: var(--muted); padding-bottom: 0.5rem;&#xA;  border-bottom: 1px solid var(--border);&#xA;  display: flex; align-items: center; gap: 0.5rem;&#xA;  margin: 0;&#xA;}&#xA;.lg-accent-bar {&#xA;  display: inline-block; width: 3px; height: 13px;&#xA;  background: var(--orange); border-radius: 2px; flex-shrink: 0;&#xA;}&#xA;.lg-param-group {&#xA;  border: 1px solid var(--border); border-radius: 6px; overflow: hidden;&#xA;}&#xA;.lg-param-row {&#xA;  display: flex; align-items: center;&#xA;  justify-content: space-between;&#xA;  padding: 0.6rem 0.85rem;&#xA;  border-bottom: 1px solid var(--border);&#xA;  gap: 0.75rem; transition: background 0.15s;&#xA;}&#xA;.lg-param-row:last-child { border-bottom: none; }&#xA;.lg-param-row:hover { background: rgba(255,255,255,0.025); }&#xA;.lg-param-label {&#xA;  font-size: 0.72rem; color: var(--muted);&#xA;  letter-spacing: 0.04em; white-space: nowrap;&#xA;  font-family: var(--mono); text-transform: uppercase;&#xA;}&#xA;.lg-input-wrap { display: flex; align-items: center; gap: 0.4rem; }&#xA;&#xA;.lg-wrap input[type=&#34;number&#34;] {&#xA;  width: 80px; padding: 0.35rem 0.5rem;&#xA;  background: var(--bg); border: 1px solid var(--border-hi);&#xA;  border-radius: 3px; color: var(--green);&#xA;  font-family: var(--mono); font-size: 0.8rem; font-weight: 500;&#xA;  text-align: right; outline: none;&#xA;  -moz-appearance: textfield;&#xA;  transition: border-color 0.2s, box-shadow 0.2s;&#xA;}&#xA;.lg-wrap input[type=&#34;number&#34;]::-webkit-inner-spin-button,&#xA;.lg-wrap input[type=&#34;number&#34;]::-webkit-outer-spin-button { opacity: 0.4; }&#xA;.lg-wrap input[type=&#34;number&#34;]:focus {&#xA;  border-color: var(--orange);&#xA;  box-shadow: 0 0 0 2px var(--orange-glow);&#xA;  color: var(--orange);&#xA;}&#xA;.lg-unit {&#xA;  font-size: 0.66rem; color: var(--muted);&#xA;  font-family: var(--mono); min-width: 22px;&#xA;}&#xA;&#xA; &#xA;.lg-btn-area {&#xA;  margin-top: auto; padding-top: 0.9rem;&#xA;  display: flex; flex-direction: column; gap: 0.6rem;&#xA;}&#xA;.lg-btn {&#xA;  width: 100%; padding: 0.8rem; border: none; border-radius: 4px;&#xA;  font-family: var(--head); font-size: 0.88rem; font-weight: 700;&#xA;  letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer;&#xA;  display: flex; align-items: center; justify-content: center; gap: 0.6rem;&#xA;  transition: transform 0.15s, box-shadow 0.2s, filter 0.15s;&#xA;  position: relative; overflow: hidden;&#xA;}&#xA;.lg-btn svg { width: 15px; height: 15px; flex-shrink: 0; }&#xA;.lg-btn-gen {&#xA;  background: var(--orange); color: #000;&#xA;  box-shadow: 0 0 20px rgba(255,106,0,0.3), 0 4px 12px rgba(255,106,0,0.2);&#xA;}&#xA;.lg-btn-gen::before {&#xA;  content: &#34;&#34;; position: absolute; inset: 0;&#xA;  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.2) 50%, transparent 60%);&#xA;  background-size: 200% 100%;&#xA;  animation: lg-shimmer 3s ease-in-out infinite;&#xA;}&#xA;@keyframes lg-shimmer {&#xA;  0%   { background-position: -200% 0; }&#xA;  100% { background-position: 200% 0; }&#xA;}&#xA;.lg-btn-gen:hover {&#xA;  transform: translateY(-2px);&#xA;  box-shadow: 0 0 30px rgba(255,106,0,0.5), 0 6px 20px rgba(255,106,0,0.3);&#xA;  filter: brightness(1.1);&#xA;}&#xA;.lg-btn-gen:active { transform: scale(0.98); }&#xA;.lg-btn-dl {&#xA;  background: transparent; color: var(--orange);&#xA;  border: 1px solid var(--orange-dim);&#xA;}&#xA;.lg-btn-dl:hover {&#xA;  background: var(--orange-glow); border-color: var(--orange);&#xA;  transform: translateY(-1px); box-shadow: 0 0 12px var(--orange-glow);&#xA;}&#xA;.lg-btn-dl:active { transform: scale(0.98); }&#xA;&#xA; &#xA;.lg-preview-panel {&#xA;  display: flex; flex-direction: column;&#xA;  background: var(--panel); min-height: 520px;&#xA;}&#xA;.lg-preview-toolbar {&#xA;  display: flex; align-items: center;&#xA;  justify-content: space-between;&#xA;  padding: 0.7rem 1.25rem;&#xA;  border-bottom: 1px solid var(--border);&#xA;  background: var(--surface);&#xA;  flex-wrap: wrap; gap: 0.5rem;&#xA;}&#xA;.lg-preview-title {&#xA;  font-family: var(--head); font-size: 0.7rem; font-weight: 700;&#xA;  letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);&#xA;  display: flex; align-items: center; gap: 0.5rem;&#xA;}&#xA;.lg-preview-stats {&#xA;  display: flex; gap: 1.2rem;&#xA;  font-family: var(--mono); font-size: 0.63rem; color: var(--muted);&#xA;}&#xA;.lg-preview-stats span { color: var(--orange); }&#xA;.lg-badge {&#xA;  font-family: var(--mono); font-size: 0.63rem; color: var(--orange);&#xA;  background: var(--orange-glow); border: 1px solid var(--orange-dim);&#xA;  padding: 0.12rem 0.5rem; border-radius: 2px; letter-spacing: 0.08em;&#xA;}&#xA;.lg-badge.off { color: var(--muted); background: transparent; border-color: var(--border); }&#xA;&#xA;.lg-preview-area {&#xA;  flex: 1; display: flex; align-items: center; justify-content: center;&#xA;  padding: 1.5rem; overflow: auto; position: relative;&#xA;}&#xA;.lg-preview-area::before {&#xA;  content: &#34;&#34;; position: absolute; inset: 0;&#xA;  background-image:&#xA;    linear-gradient(var(--border) 1px, transparent 1px),&#xA;    linear-gradient(90deg, var(--border) 1px, transparent 1px);&#xA;  background-size: 40px 40px; opacity: 0.4; pointer-events: none;&#xA;}&#xA;#lg-preview {&#xA;  position: relative; z-index: 1; max-width: 100%;&#xA;  transition: opacity 0.35s ease;&#xA;}&#xA;#lg-preview svg {&#xA;  max-width: 100%; height: auto; display: block;&#xA;  border: 1px solid var(--border);&#xA;  box-shadow: 0 0 40px rgba(0,0,0,0.6);&#xA;}&#xA;&#xA; &#xA;.lg-empty {&#xA;  display: flex; flex-direction: column; align-items: center; gap: 1rem;&#xA;  color: var(--muted); text-align: center; position: relative; z-index: 1;&#xA;}&#xA;.lg-reticle {&#xA;  width: 72px; height: 72px; border: 1.5px solid var(--border-hi);&#xA;  border-radius: 50%; position: relative;&#xA;  animation: lg-rot 12s linear infinite; flex-shrink: 0;&#xA;}&#xA;.lg-reticle::before, .lg-reticle::after {&#xA;  content: &#34;&#34;; position: absolute; background: var(--border-hi);&#xA;}&#xA;.lg-reticle::before { width: 1px; height: 100%; left: 50%; top: 0; transform: translateX(-50%); }&#xA;.lg-reticle::after  { height: 1px; width: 100%; top: 50%; left: 0; transform: translateY(-50%); }&#xA;.lg-reticle-inner {&#xA;  position: absolute; width: 36px; height: 36px;&#xA;  border: 1px solid var(--orange-dim); border-radius: 50%;&#xA;  top: 50%; left: 50%; transform: translate(-50%,-50%);&#xA;  animation: lg-rot-r 6s linear infinite;&#xA;}&#xA;.lg-reticle-dot {&#xA;  position: absolute; width: 5px; height: 5px;&#xA;  background: var(--orange); border-radius: 50%;&#xA;  top: 50%; left: 50%; transform: translate(-50%,-50%);&#xA;  box-shadow: 0 0 8px var(--orange);&#xA;  animation: lg-blink 1.5s ease-in-out infinite;&#xA;}&#xA;@keyframes lg-rot   { to { transform: rotate(360deg); } }&#xA;@keyframes lg-rot-r { to { transform: translate(-50%,-50%) rotate(-360deg); } }&#xA;.lg-empty p {&#xA;  font-family: var(--mono); font-size: 0.76rem;&#xA;  letter-spacing: 0.06em; line-height: 1.6; margin: 0;&#xA;}&#xA;.lg-empty p strong { color: var(--orange); }&#xA;&#xA; &#xA;.lg-footer {&#xA;  border-top: 1px solid var(--border); padding: 0.65rem 2rem;&#xA;  background: var(--surface); font-family: var(--mono);&#xA;  font-size: 0.63rem; color: var(--muted); letter-spacing: 0.04em;&#xA;  display: flex; align-items: center; justify-content: space-between;&#xA;  gap: 1rem; flex-wrap: wrap;&#xA;}&#xA;.lg-footer strong { color: var(--orange); }&#xA;&#xA; &#xA;.lg-toast {&#xA;  position: fixed; bottom: 2rem; left: 50%;&#xA;  transform: translateX(-50%) translateY(20px);&#xA;  background: var(--panel); border: 1px solid var(--orange-dim);&#xA;  border-radius: 3px; padding: 0.55rem 1.2rem;&#xA;  font-family: var(--mono); font-size: 0.73rem; color: var(--orange);&#xA;  letter-spacing: 0.05em;&#xA;  box-shadow: 0 0 20px rgba(255,106,0,0.15), 0 8px 30px rgba(0,0,0,0.5);&#xA;  opacity: 0; pointer-events: none; z-index: 9999;&#xA;  transition: opacity 0.3s ease, transform 0.3s cubic-bezier(.4,0,.2,1);&#xA;}&#xA;.lg-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }&#xA;&#xA; &#xA;@media (max-width: 780px) {&#xA;  .lg-main { grid-template-columns: 1fr; }&#xA;  .lg-params { border-right: none; border-bottom: 1px solid var(--border); }&#xA;  .lg-header { padding: 1rem 1.25rem; }&#xA;  .lg-header-meta { display: none; }&#xA;  .lg-footer { padding: 0.65rem 1.25rem; flex-direction: column; align-items: flex-start; gap: 0.2rem; }&#xA;}&#xA;&lt;/style&gt;&#xA;&#xA;&lt;div class=&#34;lg-wrap&#34;&gt;&#xA;&#xA;  &lt;div class=&#34;lg-header&#34;&gt;&#xA;    &lt;div class=&#34;lg-logo&#34;&gt;&#xA;      &lt;div class=&#34;lg-logo-icon&#34;&gt;&#xA;        &lt;svg viewBox=&#34;0 0 24 24&#34; fill=&#34;none&#34; stroke=&#34;currentColor&#34; stroke-width=&#34;2.2&#34; stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34;&gt;&#xA;          &lt;circle cx=&#34;12&#34; cy=&#34;12&#34; r=&#34;3&#34;/&gt;&#xA;          &lt;path d=&#34;M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83&#34;/&gt;&#xA;        &lt;/svg&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;p class=&#34;lg-logo-text&#34;&gt;LASER&lt;span&gt;GAUGE&lt;/span&gt;&lt;/p&gt;</description>
